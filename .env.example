# ==============================================================================
# FRONTEND VARIABLES (Vite / React)
# ==============================================================================
# The main base URL of your deployed frontend
VITE_SITE_URL=https://anixo.online

# URLs to your various backend services
VITE_BACKEND_API=http://localhost:5001
VITE_API_URL=http://localhost:5001
VITE_CHAT_API=http://localhost:8080
VITE_COMMENT_API_URL=http://localhost:4000
VITE_PYTHON_API=http://localhost:5000
VITE_PYTHON_API_BACKUP=

# External APIs
VITE_JIKAN_API=https://api.jikan.moe/v4
VITE_MEGAPLAY_URL=https://megaplay.buzz

# Cloudflare Turnstile (Captcha) Public Key
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADGQxfMRQroxFG6O


# ==============================================================================
# BACKEND VARIABLES (Express / Node.js)
# ==============================================================================
# Environment Mode
NODE_ENV=development

# Core App Settings
FRONTEND_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# Ports
PORT=5001
CHAT_PORT=8080
COMMENT_PORT=4000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration (SMTP) for Password Reset
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Cloudflare Turnstile Secret Key (Backend Verification)
TURNSTILE_SECRET_KEY=0x4AAAAAADGQxcZgLa0ZRtaJbL3mxiKj4RA

# AniList OAuth Configuration
ANILIST_CLIENT_ID=your_anilist_client_id
ANILIST_CLIENT_SECRET=your_anilist_client_secret
ANILIST_REDIRECT_URI=http://localhost:5173/profile

# Groq API Key (For AI Features)
GROQ_API_KEY=your_groq_api_key_here
